# --- Безопасен sqrt ---
def safe_sqrt(x):
    return np.sqrt(x) if x >= 0 else 0

# --- Основни функции за траектория на фотоните ---
def radial_potential(r, b):
    return r**4 - b**2*r**2 + 2*b**2*r

def minrs(b):
    temp = np.cbrt(b**2)*((-1 + np.sqrt(1+0j-b**2/27))**(1/3)+(-1 - np.sqrt(1+0j-b**2/27))**(1/3))
    return np.real(temp).real if np.imag(temp) < 1e-10 else 0

def d_phi_dr(r, b):
    val = radial_potential(r, b)
    if val <= 0:  # избягваме sqrt на отрицателно
        return 0
    return b / np.sqrt(val)

def phi(rs, b):
    val, _ = quad(d_phi_dr, rs, np.inf, args=(b))
    return np.nan_to_num(val, nan=0.0)

# --- Функции за траектория по x ---
def d_phi_dx(x, b, rt):
    denom = (x**2 + rt) * np.sqrt(-((b**2*(-2 + x**2 + rt)) / (x**2 + rt)) + (x**2 + rt)**2)
    if denom == 0 or np.isnan(denom) or np.iscomplex(denom):
        return 0
    return -2*b*np.abs(x) / denom

def phi_xi(xi, b):
    rt = minrs(b)
    if xi.imag != 0:
        return np.array([0])
    try:
        if rt == 0 and xi < 0:
            val = quad(d_phi_dx, np.inf, 0, args=(b, rt))[0]
        else:
            val = quad(d_phi_dx, np.inf, xi, args=(b, rt))[0]
    except:
        val = 0
    return np.nan_to_num(val, nan=0.0)

# --- Генериране на траектории ---
def generate_trajectory(ximin, ximax, b, steps):
    rt = minrs(b)
    coords = np.ndarray([steps, 2])
    for step in range(steps):
        xi = step*(ximax - ximin)/steps + ximin
        rs_val = xi**2 + rt
        coords[step][0] = rs_val
        coords[step][1] = phi_xi(xi, b)
    x_vals = coords[:,0] * np.cos(coords[:,1])
    y_vals = coords[:,0] * np.sin(coords[:,1])
    return x_vals, y_vals

# --- Функции за ротация на акреционния диск ---
def psi(phi, theta):
    return np.arccos(np.sin(theta)*np.sin(phi))

def varphi(phi, theta):
    return np.arctan2(np.cos(phi), np.cos(theta)*np.sin(phi))

# --- Параметри за визуализация ---
steps = 1000
theta = 85*np.pi/180
rmin = 5
rmax = 25
rsteps = 5

plt.figure(figsize=(8,8))

# --- Основни криви (n=0,1,2) за акреционния диск ---
for n in range(3):
    color = ['b','g','r'][n]
    for rs in range(rmin, rmax, rsteps):
        bmax = np.sqrt(rs**3 / (rs-2))
        phivals = np.linspace(0.001*np.pi, 2*np.pi*0.999, num=steps)
        varphivals = np.array([np.pi if phi >= np.pi else 0 for phi in phivals]) + \
                     np.arccos(np.sign(np.pi-phivals) * np.cos(phivals) / 
                               np.sqrt(np.cos(phivals)**2 + np.sin(phivals)**2*np.cos(theta)**2))
        psivals1 = n*np.pi + np.array([psi(phi, theta) for phi in phivals])
        xi_val = safe_sqrt(rs - minrs(bmax))
        psivals2 = np.array([[phi_xi(-xi_val, b), b] for b in np.linspace(5, bmax, num=steps)], dtype=float)
        psivals3 = np.array([[phi_xi(-xi_val, b), b] for b in np.linspace(5, bmax, num=steps)], dtype=float)
        bvals = np.array([min([min(psivals2, key=lambda x:abs(x[0]-psi)), 
                               min(psivals3, key=lambda x:abs(x[0]-psi))], 
                              key=lambda x:abs(x[0]-psi))[1] for psi in psivals1])
        alphavals = bvals * np.cos(varphivals)
        betavals = -bvals * np.sin(varphivals)
        plt.plot(alphavals, betavals, color, zorder=9-n)

