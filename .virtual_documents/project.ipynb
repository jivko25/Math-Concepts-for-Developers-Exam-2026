# Declare phi function here to use it in plot_blackhole high order function. This function is not part of visualisations.py file, because of py limitations (every time hit exception when this function is part of the py file)
def phi(xi, b):
    rt = minrs(b)

    try:
        if rt == 0 and xi < 0:
            res, _ = quad(d_phi_dx, np.inf, 0, args=(b, rt))
        else:
            res, _ = quad(d_phi_dx, np.inf, xi, args=(b, rt))
    except:
        return 0

    return res


fig, ax = plt.subplots(figsize=(8,8))

# start angle/end angle/step
# Increase end angle to 180 for better animation. Now this angle is set to 85 because of performance
angles = np.arange(10, 85, 5)

def update(angle):
    plot_blackhole(ax, phi, angle)

anim = FuncAnimation(
    fig,
    update,
    frames=angles,
    interval=500
)

plt.close()

HTML(anim.to_jshtml())





