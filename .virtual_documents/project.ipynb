# Suppress runtime warnings (like division by zero or invalid roots) 
# as they are handled by logic within the functions.
warnings.filterwarnings("ignore")

def minrs(b):
    """
    Calculates the 'turning point' (closest approach radius) for a photon 
    with impact parameter 'b' around a Schwarzschild black hole.
    Uses the analytical solution for the cubic equation of null geodesics.
    """
    with np.errstate(all='ignore'):
        # Cardano's formula for the roots of the effective potential
        val = np.cbrt(b**2) * (
            (-1 + np.sqrt(1 - b**2/27 + 0j))**(1/3) +
            (-1 - np.sqrt(1 - b**2/27 + 0j))**(1/3)
        )
    
    # If the result is NaN, the photon is likely captured (falls into the BH)
    if np.isnan(val):
        return 0
    # Return only the real part if the imaginary component is negligible
    if np.abs(np.imag(val)) < 1e-8:
        return np.real(val)
    return 0


def d_phi_dx(x, b, rt):
    """
    The integrand for the deflection angle phi. 
    Transformed to a coordinate 'x' to avoid singularities at the turning point.
    """
    denom = (x**2 + rt)
    # The term inside the square root derived from the Schwarzschild metric
    inside = (x**2 + rt)**2 - (b**2 * (-2 + x**2 + rt)) / denom

    if inside <= 0:
        return 0

    # Returns the differential change in phi relative to the radial change
    return -2*b*np.abs(x) / (denom*np.sqrt(inside))


def phi(xi, b):
    """
    Integrates the deflection angle from infinity to a specific point xi 
    along the light ray's trajectory.
    """
    rt = minrs(b)

    try:
        # Check if the ray is coming from the far side (rt=0 means event horizon)
        if rt == 0 and xi < 0:
            res,_ = quad(d_phi_dx, np.inf, 0, args=(b,rt))
        else:
            res,_ = quad(d_phi_dx, np.inf, xi, args=(b,rt))
    except:
        return 0

    return res


def psi_func(phi_val, theta):
    """Maps the bending angle to the polar angle in the disk's plane."""
    return np.arccos(np.sin(theta)*np.sin(phi_val))


def varphi_func(phi_val, theta):
    """Maps the bending angle to the azimuthal angle in the disk's plane."""
    return np.arctan2(np.cos(phi_val), np.cos(theta)*np.sin(phi_val))


def plot_blackhole(theta_deg=80):
    """
    Main function to render the accretion disk visualization.
    Calculates light paths for direct, secondary, and photon ring images.
    """
    # Convert observer inclination to radians
    theta = np.radians(theta_deg)

    # Define disk range: from 5 to 25 units of M, with steps
    rmin, rmax, rsteps = 5, 25, 5
    steps = 300

    plt.figure(figsize=(10,10))

    # Define the 'orders' of images:
    # n=0: Direct (light comes straight to observer)
    # n=1: Secondary (light loops around the BH once)
    # n=2: Photon Ring (light loops multiple times)
    orders = [
        {'n':0, 'color':'navy', 'label':'Direct'},
        {'n':1, 'color':'darkgreen', 'label':'Secondary'},
        {'n':2, 'color':'darkred', 'label':'Photon ring'}
    ]

    for order in orders:
        n = order['n']

        for rs in range(rmin, rmax, rsteps):
            # Calculate maximum impact parameter for a given radius rs
            bmax = np.sqrt(rs**3/(rs-2))

            # Sample points around the disk (0 to 2pi)
            phivals = np.linspace(0.001*np.pi, 1.999*np.pi, steps)

            # Calculate celestial coordinates for each point
            varphivals = np.array([
                varphi_func(p, theta) for p in phivals
            ])

            # Total required deflection for image order 'n'
            psivals1 = n*np.pi + np.array([
                psi_func(p, theta) for p in phivals
            ])

            # Search range for impact parameters 'b'
            b_search = np.linspace(3.001, bmax, 400)

            psivals2 = []
            psivals3 = []

            # Ray-trace to find which 'b' values result in the required 'psi'
            for b in b_search:
                rt = minrs(b)
                if rs > rt:
                    # Trajectories for light coming from both sides of the BH
                    val1 = phi(-np.sqrt(rs-rt), b)
                    val2 = phi(np.sqrt(rs-rt), b)

                    psivals2.append([val1, b])
                    psivals3.append([val2, b])

            combined = np.vstack((psivals2, psivals3))

            bvals = []
            # Match the disk geometry with the ray-traced impact parameters
            for psi in psivals1:
                idx = np.nanargmin(np.abs(combined[:, 0] - psi))
                bvals.append(combined[idx, 1])

            bvals = np.array(bvals)

            # Convert to screen coordinates (alpha, beta)
            alpha = bvals * np.cos(varphivals)
            beta = -bvals * np.sin(varphivals)
            
            # Rotate 90° for a horizontal disk orientation (typical visualization)
            x_rot = beta
            y_rot = -alpha

            plt.plot(x_rot, y_rot, color=order['color'], alpha=0.8)

    # Draw the Black Hole Shadow (radius sqrt(27) in Schwarzschild units)
    shadow = plt.Circle((0,0), np.sqrt(27), color='black')
    plt.gca().add_patch(shadow)

    # Visual formatting
    plt.gca().set_facecolor("black")
    plt.xlim(-30, 30)
    plt.ylim(-30, 30)
    plt.gca().set_aspect("equal")

    plt.title(f"Black Hole Accretion Disk (Inclination: {theta_deg}°)")
    plt.xlabel(r"$\alpha$ (Impact Parameter X)")
    plt.ylabel(r"$\beta$ (Impact Parameter Y)")

    plt.show()

# Run the simulation with 80-degree inclination
plot_blackhole(80)


